// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Main docker entrypoint",
    "adapter": "Debugpy",
    "program": "deye_docker_entrypoint.py",
    "cwd": "$ZED_WORKTREE_ROOT/src",
    "request": "launch",
  },
  {
    "label": "Display Inverter Status",
    "adapter": "Debugpy",
    "program": "mqtt_display.py",
    "cwd": "$ZED_WORKTREE_ROOT/src",
    "request": "launch",
  },
  {
    "label": "Python Active File",
    "adapter": "Debugpy",
    "program": "$ZED_FILE",
    "cwd": "$ZED_WORKTREE_ROOT",
    "request": "launch",
  },
]
